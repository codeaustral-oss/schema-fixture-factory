{
  "name": "schema-fixture-factory",
  "version": "0.1.0",
  "description": "Generate deterministic, useful JSON fixtures from JSON Schema.",
  "type": "module",
  "license": "MIT",
  "homepage": "https://github.com/codeaustral-oss/schema-fixture-factory",
  "repository": {
    "type": "git",
    "url": "https://github.com/codeaustral-oss/schema-fixture-factory.git"
  },
  "keywords": [
    "json-schema",
    "fixtures",
    "mock-data",
    "testing",
    "cli",
    "typescript"
  ],
  "bin": {
    "schema-fixture": "./dist/cli.js"
  },
  "exports": {
    ".": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "npm run build && node --test test/*.test.mjs",
    "lint": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "@types/node": "^22.19.0",
    "typescript": "^5.9.3"
  }
}
